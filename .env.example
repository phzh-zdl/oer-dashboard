# Kopiere diese Datei zu .env.local und trage deine echten Supabase-Werte ein.
# .env.local ist in .gitignore und wird NIEMALS committed.
#
# Beide Werte sind im Browser sichtbar — der Anon-Key ist absichtlich öffentlich.
# RLS (Row Level Security) auf der Datenbank schützt die Daten, nicht der Key.
# Der service_role-Key gehört NICHT hierher und niemals in den Client.

VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...
